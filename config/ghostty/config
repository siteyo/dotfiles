## Font
# font-family = "0xProto Nerd Font"
font-family = "HackGen Console NF"
font-thicken = true
font-thicken-strength = 100
font-size = 14

## Theme
theme = light:TokyoNight Day,dark:TokyoNight

## Window
macos-titlebar-style = hidden
quit-after-last-window-closed = true

## Shell Integration
shell-integration = zsh
shell-integration-features = no-cursor

## Background
background-opacity = 0.9
background-blur-radius = 20

## Cursor
cursor-style = block
cursor-style-blink = false

## Mouse
mouse-hide-while-typing = true

## Unfocused split
unfocused-split-fill = #24283b

## Keybind
keybind = ctrl+;>n=new_window
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+;>zero=reset_font_size
keybind = ctrl+;>.=reload_config
# keybind = ctrl+j=ignore
keybind = ctrl+zero=ignore

## notify
notify-on-command-finish = unfocused
notify-on-command-finish-after = 5s
notify-on-command-finish-action = no-bell,notify

## macos
macos-option-as-alt = true
desktop-notifications = true
bell-features = audio
bell-audio-path = /System/Library/Sounds/Ping.aiff
bell-audio-volume = 0.8
