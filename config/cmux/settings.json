        "ctrl+t",
        "shift+r"
      ],
      "reopenClosedBrowserPanel": "cmd+shift+t",
      "selectSurfaceByNumber": "ctrl+1",
      "selectWorkspaceByNumber": "cmd+1",
      "sendFeedback": "cmd+opt+f",
      "showBrowserJavaScriptConsole": "cmd+opt+c",
      "showNotifications": [
        "ctrl+t",
        "i"
      ],
